# Day 09 Lab — Environment Variables
# Copy file này thành .env và điền giá trị thật:
#   cp .env.example .env

# ─── OpenAI (bắt buộc cho embedding + LLM) ───
# Dùng cho: setup_index.py (text-embedding-3-small) và synthesis worker (gpt-4o-mini).
OPENAI_API_KEY=sk-...your-key-here...

# ─── Google Gemini (optional — fallback LLM) ───
# Synthesis worker thử Gemini nếu OpenAI gọi lỗi.
# GOOGLE_API_KEY=AI...your-key-here...

# ─── Embedding model (OpenAI) ───
# text-embedding-3-small: 1536-dim, giá thấp, đủ chất lượng cho 5 docs nội bộ.
# text-embedding-3-large: 3072-dim, chất lượng cao hơn, đắt hơn ~5×.
# PHẢI đồng bộ giữa setup_index.py và workers/retrieval.py — đổi thì phải re-index.
OPENAI_EMBED_MODEL=text-embedding-3-small

# ─── LLM model (synthesis) ───
OPENAI_MODEL=gpt-4o-mini

# ─── Cấu hình ChromaDB ───
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day09_docs

# ─── Cấu hình Retrieval ───
RETRIEVAL_TOP_K=3

# ─── Cấu hình MCP (Sprint 3 - optional) ───
# MCP_SERVER_URL=http://localhost:8080
# MCP_SERVER_MODE=mock   # hoặc "http" nếu dùng real HTTP server

# ─── Cấu hình Trace ───
TRACE_OUTPUT_DIR=./artifacts/traces
